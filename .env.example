# Node environment
NODE_ENV=development

# Server binding
PORT=3001
HOST=localhost

# Allowed CORS origin (your Next.js frontend URL)
CORS_ORIGIN=http://localhost:3000

# PostgreSQL connection string (same DB as frontend)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/ahar_db

# better-auth shared secret — MUST match BETTER_AUTH_SECRET in ahar-frontend .env.local
BETTER_AUTH_SECRET=replace_with_a_long_random_string_min_32_chars

# Super admin seed credentials — used once on first startup to create the admin account
SUPER_ADMIN_EMAIL=admin@ahar.com
SUPER_ADMIN_PASS=StrongPassword123!

# Cloudinary — for menu item image uploads (Feature 05)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email / SMTP — for order confirmations and reservation emails (Feature 11)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@ahar.com

# SSLCOMMERZ — Bangladesh card/mobile payment gateway (Feature 09)
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASS=
SSLCOMMERZ_IS_LIVE=false

# bKash — mobile financial service (Feature 09)
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=

# Nagad — mobile banking (Feature 09)
NAGAD_MERCHANT_ID=
NAGAD_MERCHANT_PRIVATE_KEY=
