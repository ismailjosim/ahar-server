model Coupon {
  id            String    @id @default(uuid())
  code          String    @unique
  description   String?
  discountType  String    // "flat" | "percent"
  discountValue Float
  minOrderValue Float     @default(0)
  maxUses       Int?
  usedCount     Int       @default(0)
  isActive      Boolean   @default(true)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([code])
  @@index([isActive])
}
