generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  MANAGER
  KITCHEN
  CASHIER
}

enum OrderStatus {
  PLACED
  ACCEPTED
  PREPARING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum ReservationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  phone        String?  @unique
  passwordHash String
  role         UserRole @default(MANAGER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model MenuItem {
  id          String      @id @default(uuid())
  name        String
  description String      @default("")
  category    String
  price       Float
  emoji       String?
  rating      Float       @default(4.5)
  prepTime    String?
  tags        String[]    @default([])
  variants    Json        @default("[]")
  addOns      Json        @default("[]")
  isFeatured  Boolean     @default(false)
  isSpicy     Boolean     @default(false)
  isAvailable Boolean     @default(true)
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([category])
  @@index([isAvailable])
}

model Order {
  id              String        @id @default(uuid())
  customerName    String
  phone           String
  email           String?
  fulfillmentType String
  address         String?
  notes           String?
  subtotal        Float
  deliveryFee     Float         @default(0)
  vat             Float         @default(0)
  serviceCharge   Float         @default(0)
  discount        Float         @default(0)
  total           Float
  paymentMethod   String
  paymentStatus   PaymentStatus @default(PENDING)
  status          OrderStatus   @default(PLACED)
  items           OrderItem[]
  payments        Payment[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([phone])
  @@index([status])
  @@index([paymentStatus])
}

model OrderItem {
  id              String    @id @default(uuid())
  orderId         String
  menuItemId      String?
  nameSnapshot    String
  quantity        Int
  unitPrice       Float
  selectedVariant Json?
  selectedAddOns  Json?
  lineTotal       Float
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem        MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)
}

model Reservation {
  id              String            @id @default(uuid())
  customerName    String
  phone           String
  guests          Int
  reservationTime DateTime
  tableCode       String?
  status          ReservationStatus @default(PENDING)
  occasion        String?
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([reservationTime])
  @@index([status])
}

model Payment {
  id                    String        @id @default(uuid())
  orderId               String?
  provider              String
  method                String
  amount                Float
  currency              String        @default("BDT")
  status                PaymentStatus @default(PENDING)
  providerTransactionId String?
  providerSessionId     String?
  verificationPayload   Json?
  verifiedAt            DateTime?
  refundReason          String?
  order                 Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([status])
  @@index([providerTransactionId])
}

model InventoryItem {
  id            String           @id @default(uuid())
  name          String
  category      String
  sku           String?          @unique
  stock         Float            @default(0)
  unit          String
  threshold     Float            @default(10)
  supplier      String?
  unitCost      Float            @default(0)
  lastRestocked DateTime?
  audits        InventoryAudit[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model InventoryAudit {
  id              String        @id @default(uuid())
  inventoryItemId String
  change          Float
  previousStock   Float
  nextStock       Float
  reason          String?
  changedByUserId String?
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
}

model RestaurantSettings {
  id                String   @id @default("default")
  restaurantName    String
  supportPhone      String
  supportEmail      String?
  address           String?
  openingTime       String?
  closingTime       String?
  deliveryFee       Float    @default(0)
  freeDeliveryMin   Float    @default(0)
  vatRate           Float    @default(0)
  serviceChargeRate Float    @default(0)
  acceptCod         Boolean  @default(true)
  acceptBkash       Boolean  @default(false)
  acceptNagad       Boolean  @default(false)
  acceptSslcommerz  Boolean  @default(false)
  lowStockAlerts    Boolean  @default(true)
  reservationAlerts Boolean  @default(true)
  paymentAlerts     Boolean  @default(true)
  updatedAt         DateTime @updatedAt
}

model Notification {
  id         String   @id @default(uuid())
  type       String
  severity   String
  title      String
  message    String
  read       Boolean  @default(false)
  sourceType String?
  sourceId   String?
  createdAt  DateTime @default(now())
}
