<!DOCTYPE html>
<html>
<head><meta charset="utf-8"><title>Reservation Status Update</title></head>
<body style="font-family: sans-serif; background: #fffdf9; margin: 0; padding: 20px;">
  <div style="max-width: 600px; margin: auto; background: #fff; border-radius: 16px; overflow: hidden; border: 1px solid #e8d5c4;">
    <div style="background: #b22222; padding: 24px; text-align: center;">
      <h1 style="color: #d4a017; margin: 0; font-size: 28px;"><%- restaurantName %></h1>
      <p style="color: #fff; margin: 4px 0 0;">Reservation Status</p>
    </div>
    <div style="padding: 24px;">
      <p>Dear <%- reservation.customerName %>,</p>
      <p>Your reservation status has been updated:</p>
      <div style="background: <% if (reservation.status === 'Approved') { %>#e8f5e9<% } else { %>#ffebee<% } %>; padding: 16px; border-radius: 8px; margin: 16px 0; border-left: 4px solid <% if (reservation.status === 'Approved') { %>#4caf50<% } else { %>#f44336<% } %>;">
        <p style="color: <% if (reservation.status === 'Approved') { %>#2e7d32<% } else { %>#c62828<% } %>; margin: 0; font-weight: bold; font-size: 16px;">
          <% if (reservation.status === 'Approved') { %>
            ✓ Approved
          <% } else if (reservation.status === 'Rejected') { %>
            ✗ Rejected
          <% } else { %>
            <%- reservation.status %>
          <% } %>
        </p>
        <p style="color: <% if (reservation.status === 'Approved') { %>#558b2f<% } else { %>#ad1457<% } %>; margin: 4px 0 0; font-size: 12px;">
          <% if (reservation.status === 'Approved') { %>
            Your reservation has been approved. We look forward to your visit!
          <% } else if (reservation.status === 'Rejected') { %>
            Unfortunately, we are unable to accommodate your reservation. Please try another date/time.
          <% } else { %>
            Reservation ID: #<%- reservation.id.slice(0, 8).toUpperCase() %>
          <% } %>
        </p>
      </div>
      <p style="color: #888; font-size: 12px; margin-top: 20px;">If you have any questions, please contact us.</p>
    </div>
    <div style="background: #fff8f0; padding: 16px; text-align: center; color: #888; font-size: 12px;">
      &copy; 2026 <%- restaurantName %> Restaurant. Dhaka, Bangladesh.
    </div>
  </div>
</body>
</html>
