<!DOCTYPE html>
<html>
<head><meta charset="utf-8"><title>Reservation Confirmed</title></head>
<body style="font-family: sans-serif; background: #fffdf9; margin: 0; padding: 20px;">
  <div style="max-width: 600px; margin: auto; background: #fff; border-radius: 16px; overflow: hidden; border: 1px solid #e8d5c4;">
    <div style="background: #b22222; padding: 24px; text-align: center;">
      <h1 style="color: #d4a017; margin: 0; font-size: 28px;"><%- restaurantName %></h1>
      <p style="color: #fff; margin: 4px 0 0;">Table Reservation Confirmed!</p>
    </div>
    <div style="padding: 24px;">
      <p>Dear <%- reservation.customerName %>,</p>
      <p>Your reservation has been confirmed. Here are your booking details:</p>
      <table style="width: 100%; border-collapse: collapse; margin: 16px 0;">
        <tbody>
          <tr style="background: #fff8f0;">
            <td style="padding: 12px; border-bottom: 1px solid #e8d5c4; font-weight: bold; width: 40%;">Reservation ID</td>
            <td style="padding: 12px; border-bottom: 1px solid #e8d5c4;">#<%- reservation.id.slice(0, 8).toUpperCase() %></td>
          </tr>
          <tr>
            <td style="padding: 12px; border-bottom: 1px solid #f0e8e0; font-weight: bold;">Date & Time</td>
            <td style="padding: 12px; border-bottom: 1px solid #f0e8e0;"><%- reservation.displayTime %></td>
          </tr>
          <tr style="background: #fff8f0;">
            <td style="padding: 12px; border-bottom: 1px solid #e8d5c4; font-weight: bold;">Number of Guests</td>
            <td style="padding: 12px; border-bottom: 1px solid #e8d5c4;"><%- reservation.guests %> <% if (reservation.guests === 1) { %>person<% } else { %>people<% } %></td>
          </tr>
          <% if (reservation.tableCode) { %>
          <tr>
            <td style="padding: 12px; font-weight: bold;">Table Preference</td>
            <td style="padding: 12px;"><%- reservation.tableCode %></td>
          </tr>
          <% } %>
        </tbody>
      </table>
      <p style="color: #888; font-size: 12px;">Contact: <%- reservation.phone %></p>
      <div style="background: #e8f5e9; padding: 12px; border-radius: 8px; margin: 16px 0; border-left: 4px solid #4caf50;">
        <p style="color: #2e7d32; margin: 0; font-weight: bold;">✓ Reservation Confirmed</p>
        <p style="color: #558b2f; margin: 4px 0 0; font-size: 12px;">Please arrive 10 minutes before your reservation time.</p>
      </div>
      <p style="color: #888; font-size: 12px; margin-top: 20px;">If you need to modify or cancel, please contact us as soon as possible.</p>
    </div>
    <div style="background: #fff8f0; padding: 16px; text-align: center; color: #888; font-size: 12px;">
      &copy; 2026 <%- restaurantName %> Restaurant. Dhaka, Bangladesh.
    </div>
  </div>
</body>
</html>
