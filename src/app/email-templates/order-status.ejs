<!DOCTYPE html>
<html>
<head><meta charset="utf-8"><title>Order Status Update</title></head>
<body style="font-family: sans-serif; background: #fffdf9; margin: 0; padding: 20px;">
  <div style="max-width: 600px; margin: auto; background: #fff; border-radius: 16px; overflow: hidden; border: 1px solid #e8d5c4;">
    <div style="background: #b22222; padding: 24px; text-align: center;">
      <h1 style="color: #d4a017; margin: 0; font-size: 28px;"><%- restaurantName %></h1>
      <p style="color: #fff; margin: 4px 0 0;">Order Status Update</p>
    </div>
    <div style="padding: 24px;">
      <p>Dear <%- order.customerName %>,</p>
      <p>Your order status has been updated:</p>
      <div style="background: #fff8f0; padding: 16px; border-radius: 8px; margin: 16px 0; text-align: center;">
        <p style="color: #888; font-size: 12px; margin: 0 0 4px;">Order ID: #<%- order.id.slice(0, 8).toUpperCase() %></p>
        <p style="font-size: 20px; font-weight: bold; color: #b22222; margin: 0;"><%- order.status %></p>
      </div>
      <p><a href="<%- frontendUrl %>/order-tracking?id=<%- order.id %>" style="color: #b22222; text-decoration: none; font-weight: bold;">View full tracking details →</a></p>
      <p style="color: #888; font-size: 12px; margin-top: 20px;">If you have any questions, please contact us.</p>
    </div>
    <div style="background: #fff8f0; padding: 16px; text-align: center; color: #888; font-size: 12px;">
      &copy; 2026 <%- restaurantName %> Restaurant. Dhaka, Bangladesh.
    </div>
  </div>
</body>
</html>
