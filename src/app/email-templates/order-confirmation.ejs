<!DOCTYPE html>
<html>
<head><meta charset="utf-8"><title>Order Confirmed</title></head>
<body style="font-family: sans-serif; background: #fffdf9; margin: 0; padding: 20px;">
  <div style="max-width: 600px; margin: auto; background: #fff; border-radius: 16px; overflow: hidden; border: 1px solid #e8d5c4;">
    <div style="background: #b22222; padding: 24px; text-align: center;">
      <h1 style="color: #d4a017; margin: 0; font-size: 28px;"><%- restaurantName %></h1>
      <p style="color: #fff; margin: 4px 0 0;">Order Confirmed!</p>
    </div>
    <div style="padding: 24px;">
      <p>Dear <%- order.customerName %>,</p>
      <p>Your order has been received. Here is your summary:</p>
      <p style="color: #888; font-size: 12px;">Order ID: #<%- order.id.slice(0, 8).toUpperCase() %></p>
      <table style="width: 100%; border-collapse: collapse; margin: 16px 0;">
        <thead>
          <tr style="background: #fff8f0;">
            <th style="text-align: left; padding: 8px; border-bottom: 1px solid #e8d5c4;">Item</th>
            <th style="text-align: center; padding: 8px; border-bottom: 1px solid #e8d5c4;">Qty</th>
            <th style="text-align: right; padding: 8px; border-bottom: 1px solid #e8d5c4;">Total</th>
          </tr>
        </thead>
        <tbody>
          <% order.items.forEach(item => { %>
          <tr>
            <td style="padding: 8px; border-bottom: 1px solid #f0e8e0;"><%- item.name %></td>
            <td style="text-align: center; padding: 8px; border-bottom: 1px solid #f0e8e0;"><%- item.quantity %></td>
            <td style="text-align: right; padding: 8px; border-bottom: 1px solid #f0e8e0;">৳<%- item.lineTotal.toFixed(2) %></td>
          </tr>
          <% }) %>
        </tbody>
        <tfoot>
          <tr>
            <td colspan="2" style="text-align: right; padding: 12px; font-weight: bold;">Grand Total</td>
            <td style="text-align: right; padding: 12px; font-weight: bold; color: #b22222;">৳<%- order.total.toFixed(2) %></td>
          </tr>
        </tfoot>
      </table>
      <p><strong>Fulfillment:</strong> <%- order.fulfillmentType %></p>
      <p><strong>Payment Method:</strong> <%- order.paymentMethod %></p>
      <p style="color: #888; font-size: 12px;"><a href="<%- frontendUrl %>/order-tracking?id=<%- order.id %>" style="color: #b22222; text-decoration: none;">Track your order</a></p>
    </div>
    <div style="background: #fff8f0; padding: 16px; text-align: center; color: #888; font-size: 12px;">
      &copy; 2026 <%- restaurantName %> Restaurant. Dhaka, Bangladesh.
    </div>
  </div>
</body>
</html>
